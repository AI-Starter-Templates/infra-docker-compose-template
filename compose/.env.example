# Copy to compose/.env (see .gitignore). Used by compose/dev.sh and Traefik labels.
#
# Platform note: the dev stack uses `.localhost` host names
# (`app.localhost`, `api.localhost`, `traefik.localhost`). All major browsers
# (Chrome, Firefox, Safari, Edge) resolve `*.localhost` to 127.0.0.1
# automatically on every OS, so no /etc/hosts edit is needed for browser
# use. If a shell-level lookup doesn't resolve them (older Linux libc, some
# custom resolvers), add the three names to /etc/hosts pointing at 127.0.0.1.

# dev | prod (which Compose overlay to merge)
STACK=dev

# Postgres / Valkey (base stack)
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app

# Production overlay only: real DNS names for ACME + Traefik routers.
# PUBLIC_API_HOST is ALSO baked into the SPA bundle at build time (as
# https://${PUBLIC_API_HOST}). Run `docker compose ... build --no-cache ui`
# any time it changes, or set PUBLIC_API_URL to override the full URL.
PUBLIC_API_HOST=api.example.com
PUBLIC_UI_HOST=app.example.com
ACME_EMAIL=you@example.com

# Optional: explicit full API URL baked into the SPA prod build. Useful if
# the API lives on a non-standard scheme/port. Falls back to https://${PUBLIC_API_HOST}.
# PUBLIC_API_URL=https://api.example.com

# Optional: Grafana admin when using observability overlay (Grafana on host port 3010)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Optional (dev profile): override api-dev defaults from docker-compose.yml
# API_DEV_JWT_SECRET=...   # min 32 characters
# API_DEV_FRONTEND_URL=http://app.localhost
# API_DEV_ALLOWED_ORIGINS=http://app.localhost,http://localhost:3001
# API_DEV_PUBLIC_API_URL=http://api.localhost

# --- GlitchTip (optional, WITH_GLITCHTIP=1) ------------------------------
# Self-hosted error tracking (Sentry alternative). Reuses the base stack's
# Postgres (separate `glitchtip` DB) and Valkey (DB 1). See docs/glitchtip.md.
# GLITCHTIP_SECRET_KEY=                       # REQUIRED; `openssl rand -base64 50`
#                                             # Regenerate this per environment.
#                                             # Don't copy the same value between
#                                             # dev / staging / prod, and never
#                                             # commit it (compose/.env is gitignored).
# GLITCHTIP_DOMAIN=http://glitchtip.localhost # dev default; use https://... in prod
# GLITCHTIP_DEFAULT_FROM_EMAIL=noreply@example.com
# # Dev-only auto-setup (only effective on a fresh `glitchtip` DB):
# GLITCHTIP_SUPERUSER_EMAIL=admin@localhost
# GLITCHTIP_SUPERUSER_PASSWORD=admin123456    # rotate in prod
# GLITCHTIP_DEFAULT_ORG_NAME=Local
# GLITCHTIP_DEFAULT_PROJECTS=API,Frontend
# # Prod-only:
# GLITCHTIP_PUBLIC_HOST=glitchtip.example.com   # public DNS name for ACME + routers
# GLITCHTIP_BASIC_AUTH_USERS=user:$$apr1$$...   # `htpasswd -nb user pass` (escape $ → $$)
# GLITCHTIP_EMAIL_URL=smtp://user:pass@smtp.example.com:587   # for invite + alert emails

# --- BullMQ dashboard (optional, dev-only, WITH_BULLMQ=1) ---------------
# Visualizes Bull / BullMQ jobs in the api-template's Valkey. Reachable at
# http://bullmq.localhost or http://localhost:3030 once the overlay is on.
# BULL_PREFIX must match api-template's queue prefix (default: bull).
# BULL_PREFIX=bull

# --- Resource budgets ----------------------------------------------------
# Every service has limits + reservations with sane defaults sized for a
# 4-vCPU / 8 GB single-host (the dominant cheap-VPS target). Uncomment to
# override. See docs/resource-limits.md for sizing guidance.
#
# POSTGRES_LIMITS_CPUS=1.0
# POSTGRES_LIMITS_MEMORY=512M
# POSTGRES_RESERVATIONS_CPUS=0.25
# POSTGRES_RESERVATIONS_MEMORY=128M
#
# VALKEY_LIMITS_CPUS=0.5
# VALKEY_LIMITS_MEMORY=256M
# VALKEY_RESERVATIONS_CPUS=0.1
# VALKEY_RESERVATIONS_MEMORY=64M
#
# TRAEFIK_LIMITS_CPUS=0.5
# TRAEFIK_LIMITS_MEMORY=256M
# TRAEFIK_RESERVATIONS_CPUS=0.1
# TRAEFIK_RESERVATIONS_MEMORY=64M
#
# API_DEV_LIMITS_CPUS=1.5
# API_DEV_LIMITS_MEMORY=1G
# API_DEV_RESERVATIONS_CPUS=0.25
# API_DEV_RESERVATIONS_MEMORY=256M
#
# UI_DEV_LIMITS_CPUS=1.5
# UI_DEV_LIMITS_MEMORY=1G
# UI_DEV_RESERVATIONS_CPUS=0.25
# UI_DEV_RESERVATIONS_MEMORY=256M
#
# API_LIMITS_CPUS=1.0
# API_LIMITS_MEMORY=512M
# API_RESERVATIONS_CPUS=0.25
# API_RESERVATIONS_MEMORY=128M
#
# UI_LIMITS_CPUS=0.5
# UI_LIMITS_MEMORY=128M
# UI_RESERVATIONS_CPUS=0.1
# UI_RESERVATIONS_MEMORY=32M
#
# API_MIGRATE_LIMITS_CPUS=0.5
# API_MIGRATE_LIMITS_MEMORY=512M
