# Copy to compose/.env (see .gitignore). Used by compose/dev.sh.
#
# Dev DX: browser hits Vite at http://localhost:3001 and Vite's dev-server
# proxy forwards /api/* to the api-dev container over the docker network.
# Same-origin from the browser's perspective — no CORS preflights, no
# `.localhost` subdomains, no Traefik in dev.
#
# Prod routing: Traefik on the apex domain path-routes /api/* + /health to
# the api container, everything else to the ui container. One TLS cert,
# one host, same-origin everywhere.

# dev | prod (which Compose overlay to merge)
STACK=dev

# Postgres / Valkey (base stack)
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app

# Production overlay only: real DNS name for ACME + Traefik router.
# The SPA is built domain-agnostic (VITE_API_URL=""), so this single host
# serves both the UI and /api/* in same-origin mode.
PUBLIC_UI_HOST=example.com
ACME_EMAIL=you@example.com

# Required in prod (STACK=prod). Compose fails boot with a clear error if
# any are unset. Generate JWT_SECRET with `openssl rand -base64 48`.
# JWT_SECRET=
# FRONTEND_URL=https://example.com
# PUBLIC_API_URL=https://example.com/api
# ALLOWED_ORIGINS=   # leave empty for same-origin; set if exposing api cross-origin

# GHCR image source. Defaults point at the canonical upstream images. If you
# clicked "Use this template" on GitHub, set these to your fork:
#
#   IMAGE_OWNER       — your GitHub org or user (lowercase). Always set after fork.
#   API_IMAGE_NAME    — set ONLY if you renamed your api repo (default: api-template).
#   UI_IMAGE_NAME     — set ONLY if you renamed your ui repo  (default: ui-template).
#   API_IMAGE_TAG     — default `latest`; pin to a sha-<7> or semver for prod.
#   UI_IMAGE_TAG      — same.
#
# IMAGE_OWNER=ai-starter-templates
# API_IMAGE_NAME=api-template
# UI_IMAGE_NAME=ui-template
# API_IMAGE_TAG=latest
# UI_IMAGE_TAG=latest
#
# Alternatively, override the full image reference (skips the assembly above):
# API_IMAGE=ghcr.io/me/my-saas-api:0.3.0
# UI_IMAGE=ghcr.io/me/my-saas-ui:0.5.1

# Optional: explicit full API URL baked into the SPA prod build. Leave unset
# for same-origin (the SPA uses relative `/api/*`). Override only if you
# deploy the API on a different host (cross-origin) and also set
# ALLOWED_ORIGINS in api.prod.env.
# PUBLIC_API_URL=https://api.example.com

# Optional: Grafana admin when using observability overlay (Grafana on host port 3010)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Optional (dev profile): override api-dev defaults from docker-compose.yml.
# Default is same-origin via Vite proxy — leave these unset unless you're
# exposing the api across origins (e.g., curl from a different host).
# API_DEV_JWT_SECRET=...   # min 32 characters
# API_DEV_FRONTEND_URL=http://localhost:3001
# API_DEV_ALLOWED_ORIGINS=
# API_DEV_PUBLIC_API_URL=http://localhost:3001/api

# Optional: first-boot superuser. Both must be set for the api-migrate
# one-shot to seed an admin account. THIS FILE is the right place — the
# api-migrate service in docker-compose.yml reads `${SUPERUSER_EMAIL}` from
# here, NOT from api-template/.env (Compose doesn't read it; an explicit
# empty default in the service overrides anything Bun's .env loader does
# inside the container). Uncomment to enable; rotate before going to prod.
# SUPERUSER_EMAIL=demo@example.com
# SUPERUSER_PASSWORD=password123

# --- GlitchTip (optional, WITH_GLITCHTIP=1) ------------------------------
# Self-hosted error tracking (Sentry alternative). Reuses the base stack's
# Postgres (separate `glitchtip` DB) and Valkey (DB 1). See docs/glitchtip.md.
# GLITCHTIP_SECRET_KEY=                       # REQUIRED; `openssl rand -base64 50`
#                                             # Regenerate this per environment.
#                                             # Don't copy the same value between
#                                             # dev / staging / prod, and never
#                                             # commit it (compose/.env is gitignored).
# GLITCHTIP_DOMAIN=http://glitchtip.localhost # dev default; use https://... in prod
# GLITCHTIP_DEFAULT_FROM_EMAIL=noreply@example.com
# # Dev-only auto-setup (only effective on a fresh `glitchtip` DB):
# GLITCHTIP_SUPERUSER_EMAIL=admin@localhost
# GLITCHTIP_SUPERUSER_PASSWORD=admin123456    # rotate in prod
# GLITCHTIP_DEFAULT_ORG_NAME=Local
# GLITCHTIP_DEFAULT_PROJECTS=API,Frontend
# # Prod-only:
# GLITCHTIP_PUBLIC_HOST=glitchtip.example.com   # public DNS name for ACME + routers
# GLITCHTIP_BASIC_AUTH_USERS=user:$$apr1$$...   # `htpasswd -nb user pass` (escape $ → $$)
# GLITCHTIP_EMAIL_URL=smtp://user:pass@smtp.example.com:587   # for invite + alert emails

# --- Mailpit (optional, dev-only, WITH_MAILPIT=1) -----------------------
# Local SMTP catcher. Captures emails sent by the api when EMAIL_PROVIDER=smtp
# and SMTP_HOST=mailpit (configured in api.dev.env or compose/.env). Web UI
# at http://localhost:8025; SMTP on localhost:1025. No auth required.
# MAILPIT_LIMITS_CPUS=0.25
# MAILPIT_LIMITS_MEMORY=128M

# --- BullMQ dashboard (optional, dev-only, WITH_BULLMQ=1) ---------------
# Visualizes Bull / BullMQ jobs in the api-template's Valkey. Reachable at
# http://bullmq.localhost or http://localhost:3030 once the overlay is on.
# BULL_PREFIX must match api-template's queue prefix (default: bull).
# BULL_PREFIX=bull

# --- Resource budgets ----------------------------------------------------
# Every service has limits + reservations with sane defaults sized for a
# 4-vCPU / 8 GB single-host (the dominant cheap-VPS target). Uncomment to
# override. See docs/resource-limits.md for sizing guidance.
#
# POSTGRES_LIMITS_CPUS=1.0
# POSTGRES_LIMITS_MEMORY=512M
# POSTGRES_RESERVATIONS_CPUS=0.25
# POSTGRES_RESERVATIONS_MEMORY=128M
#
# VALKEY_LIMITS_CPUS=0.5
# VALKEY_LIMITS_MEMORY=256M
# VALKEY_RESERVATIONS_CPUS=0.1
# VALKEY_RESERVATIONS_MEMORY=64M
#
# TRAEFIK_LIMITS_CPUS=0.5
# TRAEFIK_LIMITS_MEMORY=256M
# TRAEFIK_RESERVATIONS_CPUS=0.1
# TRAEFIK_RESERVATIONS_MEMORY=64M
#
# API_DEV_LIMITS_CPUS=1.5
# API_DEV_LIMITS_MEMORY=1G
# API_DEV_RESERVATIONS_CPUS=0.25
# API_DEV_RESERVATIONS_MEMORY=256M
#
# UI_DEV_LIMITS_CPUS=1.5
# UI_DEV_LIMITS_MEMORY=1G
# UI_DEV_RESERVATIONS_CPUS=0.25
# UI_DEV_RESERVATIONS_MEMORY=256M
#
# API_LIMITS_CPUS=1.0
# API_LIMITS_MEMORY=512M
# API_RESERVATIONS_CPUS=0.25
# API_RESERVATIONS_MEMORY=128M
#
# UI_LIMITS_CPUS=0.5
# UI_LIMITS_MEMORY=128M
# UI_RESERVATIONS_CPUS=0.1
# UI_RESERVATIONS_MEMORY=32M
#
# API_MIGRATE_LIMITS_CPUS=0.5
# API_MIGRATE_LIMITS_MEMORY=512M
