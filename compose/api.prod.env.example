# Copy to compose/api.prod.env and fill in before: STACK=prod ./scripts/compose-up.sh
# DATABASE_URL / VALKEY_* / PORT are set in docker-compose.yml for the api service.

JWT_SECRET=replace-with-openssl-rand-base64-48
ALLOWED_ORIGINS=https://app.example.com
FRONTEND_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com

# --- Email — Cloudflare Email Service (default) ------------------------
# Setup: docs/runbooks/cloudflare-email.md
# Both vars are required in prod when EMAIL_PROVIDER=cloudflare.
EMAIL_PROVIDER=cloudflare
EMAIL_FROM=noreply@example.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=

# Add the rest from api-template/.env.example for your features (OAuth, Stripe, etc.)
